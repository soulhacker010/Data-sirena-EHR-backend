# ─── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_ADMIN_URL=admin

# Production only — comma-separated, must include https://
# CSRF_TRUSTED_ORIGINS=https://sirena-ehr-backend.onrender.com,https://yourdomain.com

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/sirena_ehr
DATABASE_SSL_REQUIRE=false

# ─── JWT ───────────────────────────────────────────────────────────────────────
SIMPLE_JWT_ACCESS_LIFETIME_MINUTES=15
SIMPLE_JWT_REFRESH_LIFETIME_DAYS=7

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Throttle Rates ───────────────────────────────────────────────────────────
DRF_THROTTLE_USER=100/min
DRF_THROTTLE_ANON=20/min
DRF_THROTTLE_LOGIN=5/min
DRF_THROTTLE_EMAIL=10/min

# ─── Stripe (use sk_test_ keys for development) ───────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
DEFAULT_FROM_EMAIL=no-reply@sirenahealthehr.com
RESEND_REPLY_TO=

# ─── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Application ──────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:5173
